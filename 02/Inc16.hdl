// File name: projects/2/Inc16.hdl
/**
 * 16-bit incrementer:
 * out = in + 1
 */
CHIP Inc16 {
    IN in[16];
    OUT out[16];

    PARTS:
    Not16(in=in, out=notin);
    Or16(a=in, b=notin, out=all1);
    Add16(a=all1, b=all1, out=last0);
    Not16(in=last0, out=one);
    Add16(a =in, b =one, out =out);
}